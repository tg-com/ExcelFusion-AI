<script>
(async function(){

const loading = document.getElementById("loading");
const app = document.getElementById("app");
const loginScreen = document.getElementById("loginScreen");

const chatContainer = document.getElementById("chatContainer");
const chatInput = document.getElementById("chatInput");
const sendBtn = document.getElementById("sendBtn");
const deleteChatBtn = document.getElementById("deleteChatBtn");
const apiSettingsBtn = document.getElementById("apiSettingsBtn");

function applyTheme(){
const theme = localStorage.getItem("theme") || "light";
if(theme === "dark"){
document.documentElement.classList.add("dark");
} else {
document.documentElement.classList.remove("dark");
}
}

document.getElementById("themeToggle").onclick = () => {
const current = localStorage.getItem("theme") || "light";
localStorage.setItem("theme", current === "light" ? "dark" : "light");
applyTheme();
};

applyTheme();

async function getKey(){
const rawKey = await crypto.subtle.digest("SHA-256", new TextEncoder().encode("enterprise-secret-key"));
return crypto.subtle.importKey("raw", rawKey, "AES-GCM", false, ["encrypt","decrypt"]);
}

async function encryptData(data){
try{
const key = await getKey();
const iv = crypto.getRandomValues(new Uint8Array(12));
const encoded = new TextEncoder().encode(JSON.stringify(data));
const ciphertext = await crypto.subtle.encrypt({name:"AES-GCM", iv}, key, encoded);
return {iv:Array.from(iv),data:Array.from(new Uint8Array(ciphertext))};
}catch(e){return null;}
}

async function decryptData(encrypted){
try{
const key = await getKey();
const iv = new Uint8Array(encrypted.iv);
const data = new Uint8Array(encrypted.data);
const decrypted = await crypto.subtle.decrypt({name:"AES-GCM", iv}, key, data);
return JSON.parse(new TextDecoder().decode(decrypted));
}catch(e){return null;}
}

async function loadUsers(){
const encrypted = localStorage.getItem("users");
if(!encrypted) return [];
return await decryptData(JSON.parse(encrypted)) || [];
}

async function saveUsers(users){
const encrypted = await encryptData(users);
if(encrypted) localStorage.setItem("users", JSON.stringify(encrypted));
}

async function loadChats(username){
const encrypted = localStorage.getItem("chat_"+username);
if(!encrypted) return [];
return await decryptData(JSON.parse(encrypted)) || [];
}

async function saveChats(username,chats){
const encrypted = await encryptData(chats);
if(encrypted) localStorage.setItem("chat_"+username, JSON.stringify(encrypted));
}

async function login(){
const username = document.getElementById("usernameInput").value.trim();
const role = document.getElementById("roleSelect").value;
if(!username) return;

let users = await loadUsers();
let existing = users.find(u => u.username === username);
if(!existing){
users.push({username,role});
await saveUsers(users);
}
localStorage.setItem("sessionUser", username);
initApp();
}

document.getElementById("loginBtn").onclick = login;

async function initApp(){
const username = localStorage.getItem("sessionUser");
if(!username){
loginScreen.classList.remove("hidden");
app.classList.add("hidden");
loading.classList.add("hidden");
return;
}

const users = await loadUsers();
const user = users.find(u => u.username === username);

document.getElementById("currentUser").textContent = user.username;
document.getElementById("currentRole").textContent = user.role;

if(user.role === "Admin"){
document.getElementById("manageUsersBtn").classList.remove("hidden");
apiSettingsBtn.classList.remove("hidden");
}

loginScreen.classList.add("hidden");
app.classList.remove("hidden");
loading.classList.add("hidden");

loadChatUI();
}

async function loadChatUI(){
chatContainer.innerHTML="";
const username = localStorage.getItem("sessionUser");
const chats = await loadChats(username);

chats.forEach(msg=>{
addMessage(msg.role,msg.content);
});
}

function addMessage(role,content){
const div=document.createElement("div");
div.className = role==="user"?
"text-right":
"text-left";
div.innerHTML = `<div class="inline-block px-3 py-2 rounded ${
role==="user"?
"bg-blue-500 text-white":
"bg-gray-200 dark:bg-gray-700 dark:text-white"
}">${marked.parse(content)}</div>`;
chatContainer.appendChild(div);
chatContainer.scrollTop=chatContainer.scrollHeight;
}

async function sendMessage(){
const text=chatInput.value.trim();
if(!text) return;
chatInput.value="";

addMessage("user",text);

const username=localStorage.getItem("sessionUser");
let chats=await loadChats(username);
chats.push({role:"user",content:text});
await saveChats(username,chats);

const aiDiv=document.createElement("div");
aiDiv.className="text-left";
aiDiv.innerHTML=`<div class="inline-block px-3 py-2 rounded bg-gray-200 dark:bg-gray-700 dark:text-white"></div>`;
chatContainer.appendChild(aiDiv);
const aiBox=aiDiv.firstChild;

let responseText="";

try{
const res=await fetch("https://openrouter.ai/api/v1/chat/completions",{
method:"POST",
headers:{
"Content-Type":"application/json",
"Authorization":"Bearer "+(localStorage.getItem("apiKey")||"")
},
body:JSON.stringify({
model:localStorage.getItem("model")||"deepseek/deepseek-r1:free",
stream:true,
messages:[...chats,{role:"user",content:text}]
})
});

const reader=res.body.getReader();
const decoder=new TextDecoder();

while(true){
const {done,value}=await reader.read();
if(done) break;
const chunk=decoder.decode(value);
responseText+=chunk;
aiBox.innerHTML=marked.parse(responseText);
chatContainer.scrollTop=chatContainer.scrollHeight;
}

}catch(e){
aiBox.innerHTML="Error: API issue";
}

chats.push({role:"assistant",content:responseText});
await saveChats(username,chats);
}

sendBtn.onclick=sendMessage;

deleteChatBtn.onclick=async()=>{
const username=localStorage.getItem("sessionUser");
await saveChats(username,[]);
chatContainer.innerHTML="";
};

document.getElementById("logoutBtn").onclick=()=>{
localStorage.removeItem("sessionUser");
location.reload();
};

await initApp();

})();
</script>

