<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Universal AI Workspace – Enterprise Secure</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 transition-colors duration-300 min-h-screen flex flex-col">

<div id="loading" class="fixed inset-0 flex items-center justify-center bg-white dark:bg-gray-900 z-50">
  <div class="text-lg font-semibold text-gray-700 dark:text-gray-200">Loading App...</div>
</div>

<div id="app" class="flex flex-1 hidden">

  <!-- Sidebar -->
  <aside class="w-64 bg-white dark:bg-gray-800 shadow-lg p-4 flex flex-col">
    <h1 class="text-xl font-bold text-gray-800 dark:text-white mb-4">AI Workspace</h1>
    
    <div class="mb-4">
      <div class="text-sm text-gray-500 dark:text-gray-400">Logged in as:</div>
      <div id="currentUser" class="font-semibold text-gray-800 dark:text-white"></div>
      <div id="currentRole" class="text-xs text-blue-600 dark:text-blue-400"></div>
    </div>

    <button id="manageUsersBtn" class="mb-2 px-3 py-2 rounded bg-blue-500 text-white text-sm hidden">
      Manage Users
    </button>

    <button id="logoutBtn" class="mt-auto px-3 py-2 rounded bg-red-500 text-white text-sm">
      Logout
    </button>

    <div class="mt-4 flex items-center justify-between">
      <button id="langToggle" class="text-xs px-2 py-1 bg-gray-200 dark:bg-gray-700 rounded">हिन्दी</button>
      <button id="themeToggle" class="text-xs px-2 py-1 bg-gray-200 dark:bg-gray-700 rounded">🌙</button>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 p-6 overflow-auto">
    <div id="dashboard" class="text-gray-800 dark:text-gray-200">
      <h2 class="text-2xl font-bold mb-4">Dashboard</h2>
      <p>This is secure enterprise core system (Part 1 ready).</p>
    </div>
  </main>
</div>

<!-- Login Screen -->
<div id="loginScreen" class="flex flex-1 items-center justify-center p-4">
  <div class="bg-white dark:bg-gray-800 p-6 rounded shadow-lg w-full max-w-sm">
    <h2 class="text-xl font-bold mb-4 text-gray-800 dark:text-white">Login</h2>

    <input id="usernameInput" type="text" placeholder="Username"
      class="w-full mb-3 px-3 py-2 border rounded bg-gray-50 dark:bg-gray-700 dark:text-white"/>

    <select id="roleSelect"
      class="w-full mb-4 px-3 py-2 border rounded bg-gray-50 dark:bg-gray-700 dark:text-white">
      <option value="Admin">Admin</option>
      <option value="User">User</option>
    </select>

    <button id="loginBtn"
      class="w-full bg-blue-500 text-white px-3 py-2 rounded">
      Login
    </button>
  </div>
</div>

<script>
(async function(){

// =============================
// Safe Init
// =============================
const loading = document.getElementById("loading");
const app = document.getElementById("app");
const loginScreen = document.getElementById("loginScreen");

// =============================
// Language System
// =============================
const translations = {
  en: { dashboard: "Dashboard", login: "Login" },
  hi: { dashboard: "डैशबोर्ड", login: "लॉगिन" }
};

let currentLang = localStorage.getItem("lang") || "en";

function applyLanguage(){
  document.documentElement.lang = currentLang;
}

document.getElementById("langToggle").onclick = () => {
  currentLang = currentLang === "en" ? "hi" : "en";
  localStorage.setItem("lang", currentLang);
  applyLanguage();
};

applyLanguage();

// =============================
// Dark Mode
// =============================
function applyTheme(){
  const theme = localStorage.getItem("theme") || "light";
  if(theme === "dark"){
    document.documentElement.classList.add("dark");
  } else {
    document.documentElement.classList.remove("dark");
  }
}

document.getElementById("themeToggle").onclick = () => {
  const current = localStorage.getItem("theme") || "light";
  localStorage.setItem("theme", current === "light" ? "dark" : "light");
  applyTheme();
};

applyTheme();

// =============================
// Encryption System (AES-GCM)
// =============================
async function getKey(){
  const rawKey = await crypto.subtle.digest("SHA-256", new TextEncoder().encode("enterprise-secret-key"));
  return crypto.subtle.importKey("raw", rawKey, "AES-GCM", false, ["encrypt","decrypt"]);
}

async function encryptData(data){
  try{
    const key = await getKey();
    const iv = crypto.getRandomValues(new Uint8Array(12));
    const encoded = new TextEncoder().encode(JSON.stringify(data));
    const ciphertext = await crypto.subtle.encrypt({name:"AES-GCM", iv}, key, encoded);
    return {
      iv: Array.from(iv),
      data: Array.from(new Uint8Array(ciphertext))
    };
  }catch(e){
    return null;
  }
}

async function decryptData(encrypted){
  try{
    const key = await getKey();
    const iv = new Uint8Array(encrypted.iv);
    const data = new Uint8Array(encrypted.data);
    const decrypted = await crypto.subtle.decrypt({name:"AES-GCM", iv}, key, data);
    return JSON.parse(new TextDecoder().decode(decrypted));
  }catch(e){
    return null;
  }
}

// =============================
// Multi User System
// =============================
async function loadUsers(){
  const encrypted = localStorage.getItem("users");
  if(!encrypted) return [];
  return await decryptData(JSON.parse(encrypted)) || [];
}

async function saveUsers(users){
  const encrypted = await encryptData(users);
  if(encrypted){
    localStorage.setItem("users", JSON.stringify(encrypted));
  }
}

async function login(){
  const username = document.getElementById("usernameInput").value.trim();
  const role = document.getElementById("roleSelect").value;

  if(!username) return;

  let users = await loadUsers();
  let existing = users.find(u => u.username === username);

  if(!existing){
    users.push({username, role});
    await saveUsers(users);
  }

  localStorage.setItem("sessionUser", username);
  initApp();
}

document.getElementById("loginBtn").onclick = login;

async function initApp(){
  const username = localStorage.getItem("sessionUser");
  if(!username){
    loginScreen.classList.remove("hidden");
    app.classList.add("hidden");
    loading.classList.add("hidden");
    return;
  }

  const users = await loadUsers();
  const user = users.find(u => u.username === username);

  document.getElementById("currentUser").textContent = user.username;
  document.getElementById("currentRole").textContent = user.role;

  if(user.role === "Admin"){
    document.getElementById("manageUsersBtn").classList.remove("hidden");
  }

  loginScreen.classList.add("hidden");
  app.classList.remove("hidden");
  loading.classList.add("hidden");
}

document.getElementById("logoutBtn").onclick = () => {
  localStorage.removeItem("sessionUser");
  location.reload();
};

await initApp();

})();
</script>

</body>
</html>
