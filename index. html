<script src="https://cdn.jsdelivr.net/npm/jspdf/dist/jspdf.umd.min.js"></script>
</head>

<body class="bg-gray-100 dark:bg-gray-900 min-h-screen flex flex-col transition-colors duration-300">

<div id="loading" class="fixed inset-0 flex items-center justify-center bg-white dark:bg-gray-900 z-50">
<div class="text-lg font-semibold text-gray-700 dark:text-gray-200">Loading App...</div>
</div>

<div id="app" class="flex flex-1 hidden">

<!-- Sidebar -->
<aside class="w-64 bg-white dark:bg-gray-800 shadow-lg p-4 flex flex-col">
<h1 class="text-xl font-bold text-gray-800 dark:text-white mb-4">AI Workspace</h1>

<div class="mb-4">
<div class="text-sm text-gray-500 dark:text-gray-400">User:</div>
<div id="currentUser" class="font-semibold text-gray-800 dark:text-white"></div>
</div>

<button id="chatModeBtn" class="mb-2 px-3 py-2 rounded bg-blue-500 text-white text-sm">Chat</button>
<button id="ocrModeBtn" class="mb-2 px-3 py-2 rounded bg-green-500 text-white text-sm">OCR Scanner</button>

<button id="logoutBtn" class="mt-auto px-3 py-2 rounded bg-red-500 text-white text-sm">Logout</button>

<div class="mt-4">
<button id="themeToggle" class="text-xs px-2 py-1 bg-gray-200 dark:bg-gray-700 rounded">🌙</button>
</div>
</aside>

<main class="flex-1 flex flex-col">

<!-- CHAT -->
<div id="chatSection" class="flex flex-col flex-1">
<div id="chatContainer" class="flex-1 overflow-auto p-4 space-y-4"></div>
<div class="p-3 border-t dark:border-gray-700 bg-white dark:bg-gray-800">
<div class="flex space-x-2">
<input id="chatInput" class="flex-1 px-3 py-2 rounded border dark:bg-gray-700 dark:text-white" placeholder="Type message..."/>
<button id="sendBtn" class="px-4 py-2 bg-blue-500 text-white rounded">Send</button>
<button id="deleteChatBtn" class="px-4 py-2 bg-red-500 text-white rounded">Clear</button>
</div>
</div>
</div>

<!-- OCR -->
<div id="ocrSection" class="hidden flex-1 overflow-auto p-4 space-y-4">

<input type="file" id="imageInput" multiple accept="image/*"
class="block w-full text-sm text-gray-700 dark:text-white"/>

<button id="processBtn" class="px-4 py-2 bg-green-600 text-white rounded">
Process Images
</button>

<div class="flex space-x-2">
<button id="excelBtn" class="px-4 py-2 bg-blue-600 text-white rounded hidden">
Export Excel
</button>
<button id="pdfBtn" class="px-4 py-2 bg-purple-600 text-white rounded hidden">
Export PDF
</button>
</div>

<div id="ocrResults" class="space-y-4"></div>

</div>

</main>
</div>

<div id="loginScreen" class="flex flex-1 items-center justify-center p-4">
<div class="bg-white dark:bg-gray-800 p-6 rounded shadow-lg w-full max-w-sm">
<h2 class="text-xl font-bold mb-4 text-gray-800 dark:text-white">Login</h2>
<input id="usernameInput" type="text" placeholder="Username"
class="w-full mb-3 px-3 py-2 border rounded bg-gray-50 dark:bg-gray-700 dark:text-white"/>
<button id="loginBtn"
class="w-full bg-blue-500 text-white px-3 py-2 rounded">
Login
</button>
</div>
</div>

<script>
(async function(){

const loading = document.getElementById("loading");
const app = document.getElementById("app");
const loginScreen = document.getElementById("loginScreen");
const chatSection = document.getElementById("chatSection");
const ocrSection = document.getElementById("ocrSection");

let ocrData = [];

document.getElementById("chatModeBtn").onclick=()=>{
chatSection.classList.remove("hidden");
ocrSection.classList.add("hidden");
};

document.getElementById("ocrModeBtn").onclick=()=>{
ocrSection.classList.remove("hidden");
chatSection.classList.add("hidden");
};

document.getElementById("themeToggle").onclick=()=>{
const theme = document.documentElement.classList.contains("dark")?"light":"dark";
localStorage.setItem("theme",theme);
document.documentElement.classList.toggle("dark");
};

document.getElementById("loginBtn").onclick=()=>{
const username=document.getElementById("usernameInput").value.trim();
if(!username) return;
localStorage.setItem("sessionUser",username);
initApp();
};

function initApp(){
const username=localStorage.getItem("sessionUser");
if(!username){
loginScreen.classList.remove("hidden");
app.classList.add("hidden");
loading.classList.add("hidden");
return;
}
document.getElementById("currentUser").textContent=username;
loginScreen.classList.add("hidden");
app.classList.remove("hidden");
loading.classList.add("hidden");
}

document.getElementById("logoutBtn").onclick=()=>{
localStorage.removeItem("sessionUser");
location.reload();
};

function detectFields(text){
const nameMatch = text.match(/Name[:\s]+([A-Za-z ]+)/i);
const dateMatch = text.match(/\b(\d{1,2}[-\/]\d{1,2}[-\/]\d{2,4})\b/);
const amountMatch = text.match(/(Total|Amount)[^\d]*([\d,.]+)/i);
let amount = amountMatch ? parseFloat(amountMatch[2].replace(/,/g,'')) : 0;
let gst = amount * 0.18;
return {
name: nameMatch ? nameMatch[1] : "",
date: dateMatch ? dateMatch[1] : "",
amount,
gst,
total: amount+gst,
raw:text
};
}

document.getElementById("processBtn").onclick=async()=>{
const files=document.getElementById("imageInput").files;
if(!files.length) return;

ocrData=[];
document.getElementById("ocrResults").innerHTML="";

for(let i=0;i<files.length && i<25;i++){
const file=files[i];
const block=document.createElement("div");
block.className="p-4 border rounded bg-white dark:bg-gray-800 dark:text-white";
block.innerHTML="Processing "+file.name+"...";
document.getElementById("ocrResults").appendChild(block);

try{
const { data:{text} } = await Tesseract.recognize(file,'eng+hin');
const fields=detectFields(text);
fields.file=file.name;
ocrData.push(fields);

block.innerHTML=`
<div class="font-semibold">${file.name}</div>
<div>Name: ${fields.name}</div>
<div>Date: ${fields.date}</div>
<div>Amount: ₹${fields.amount.toFixed(2)}</div>
<div>GST (18%): ₹${fields.gst.toFixed(2)}</div>
<div>Total: ₹${fields.total.toFixed(2)}</div>
`;

}catch(e){
block.innerHTML="Error processing "+file.name;
}
}

if(ocrData.length){
document.getElementById("excelBtn").classList.remove("hidden");
document.getElementById("pdfBtn").classList.remove("hidden");
}
};

document.getElementById("excelBtn").onclick=()=>{
const ws=XLSX.utils.json_to_sheet(ocrData);
const wb=XLSX.utils.book_new();
XLSX.utils.book_append_sheet(wb,ws,"Bills");
XLSX.writeFile(wb,"ai-bill-extracted.xlsx");
};

document.getElementById("pdfBtn").onclick=()=>{
const { jsPDF } = window.jspdf;
const doc=new jsPDF();
let y=10;

doc.setFontSize(16);
doc.text("AI Bill Report",10,y);
y+=10;

ocrData.forEach((item,i)=>{
doc.setFontSize(12);
doc.text(`File: ${item.file}`,10,y); y+=6;
doc.text(`Name: ${item.name}`,10,y); y+=6;
doc.text(`Date: ${item.date}`,10,y); y+=6;
doc.text(`Amount: ${item.amount}`,10,y); y+=6;
doc.text(`GST: ${item.gst}`,10,y); y+=6;
doc.text(`Total: ${item.total}`,10,y); y+=10;
if(y>270){doc.addPage();y=10;}
});

doc.save("ai-bill-report.pdf");
};

initApp();

})();
</script>

</body>
</html>
